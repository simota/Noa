#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENDOR_DIR="${REPO_ROOT}/crates/noa-theme/vendor"
THEME_DIR="${VENDOR_DIR}/themes"
ATTRIBUTION="${VENDOR_DIR}/ATTRIBUTION.md"
OUT="${REPO_ROOT}/crates/noa-theme/src/generated.rs"

if [[ ! -f "${ATTRIBUTION}" ]]; then
  echo "missing theme attribution manifest: ${ATTRIBUTION}" >&2
  exit 1
fi

if [[ ! -d "${THEME_DIR}" ]]; then
  echo "missing theme vendor directory: ${THEME_DIR}" >&2
  exit 1
fi

python3 - "${THEME_DIR}" "${OUT}" <<'PY'
from pathlib import Path
import re
import sys

theme_dir = Path(sys.argv[1])
out_path = Path(sys.argv[2])

HEX_RE = re.compile(r"^#?([0-9a-fA-F]{6})$")
PALETTE_RE = re.compile(r"^([0-9]{1,3})\s*=\s*(#[0-9a-fA-F]{6})$")


def parse_rgb(value, path, line_no):
    match = HEX_RE.match(value.strip())
    if not match:
        raise SystemExit(f"{path}:{line_no}: invalid RGB value: {value!r}")
    return int(match.group(1), 16)


def parse_theme(path):
    values = {}
    palette = {}

    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue

        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()

        if key == "palette":
            match = PALETTE_RE.match(value)
            if not match:
                raise SystemExit(f"{path}:{line_no}: invalid palette entry: {value!r}")
            index = int(match.group(1))
            if index > 255:
                raise SystemExit(f"{path}:{line_no}: palette index out of range: {index}")
            palette[index] = parse_rgb(match.group(2), path, line_no)
            continue

        if key in {
            "background",
            "foreground",
            "cursor-color",
            "cursor-text",
            "selection-background",
            "selection-foreground",
        }:
            values[key] = parse_rgb(value, path, line_no)

    for key in ("background", "foreground"):
        if key not in values:
            raise SystemExit(f"{path}: missing required {key!r} color")

    default_bg = values["background"]
    default_fg = values["foreground"]
    cursor = values.get("cursor-color", default_fg)
    selection_bg = values.get("selection-background", default_fg)
    selection_fg = values.get("selection-foreground", default_bg)

    return {
        "name": path.stem,
        "default_fg": default_fg,
        "default_bg": default_bg,
        "cursor": cursor,
        "selection_fg": selection_fg,
        "selection_bg": selection_bg,
        "palette": sorted(palette.items()),
    }


def rgb(value):
    return f"rgb(0x{value:06x})"


def rust_str(value):
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


paths = sorted(theme_dir.glob("*.conf"), key=lambda p: p.stem)
if not paths:
    raise SystemExit(f"{theme_dir}: no theme .conf files found")

themes = [parse_theme(path) for path in paths]
names = [theme["name"] for theme in themes]
if len(names) != len(set(names)):
    raise SystemExit("duplicate theme names in vendor snapshot")

lines = [
    "// This file is generated by scripts/gen-themes.",
    "// Edit vendored theme files, then rerun that script.",
    "",
    "use crate::ThemeDef;",
    "use noa_core::Rgb;",
    "",
    "const fn rgb(hex: u32) -> Rgb {",
    "    Rgb::new(",
    "        ((hex >> 16) & 0xff) as u8,",
    "        ((hex >> 8) & 0xff) as u8,",
    "        (hex & 0xff) as u8,",
    "    )",
    "}",
    "",
    "const fn xterm_palette() -> [Rgb; 256] {",
    "    let mut p = [rgb(0x000000); 256];",
    "",
    "    p[0] = rgb(0x000000);",
    "    p[1] = rgb(0xcd0000);",
    "    p[2] = rgb(0x00cd00);",
    "    p[3] = rgb(0xcdcd00);",
    "    p[4] = rgb(0x0000ee);",
    "    p[5] = rgb(0xcd00cd);",
    "    p[6] = rgb(0x00cdcd);",
    "    p[7] = rgb(0xe5e5e5);",
    "    p[8] = rgb(0x7f7f7f);",
    "    p[9] = rgb(0xff0000);",
    "    p[10] = rgb(0x00ff00);",
    "    p[11] = rgb(0xffff00);",
    "    p[12] = rgb(0x5c5cff);",
    "    p[13] = rgb(0xff00ff);",
    "    p[14] = rgb(0x00ffff);",
    "    p[15] = rgb(0xffffff);",
    "",
    "    let steps = [0x00, 0x5f, 0x87, 0xaf, 0xd7, 0xff];",
    "    let mut idx = 16usize;",
    "    let mut r = 0usize;",
    "    while r < 6 {",
    "        let mut g = 0usize;",
    "        while g < 6 {",
    "            let mut b = 0usize;",
    "            while b < 6 {",
    "                p[idx] = Rgb::new(steps[r], steps[g], steps[b]);",
    "                idx += 1;",
    "                b += 1;",
    "            }",
    "            g += 1;",
    "        }",
    "        r += 1;",
    "    }",
    "",
    "    let mut i = 0u8;",
    "    while i < 24 {",
    "        let v = 8 + i * 10;",
    "        p[232 + i as usize] = Rgb::new(v, v, v);",
    "        i += 1;",
    "    }",
    "",
    "    p",
    "}",
    "",
    "const fn palette(overrides: &[(usize, Rgb)]) -> [Rgb; 256] {",
    "    let mut p = xterm_palette();",
    "    let mut i = 0usize;",
    "    while i < overrides.len() {",
    "        let (index, color) = overrides[i];",
    "        p[index] = color;",
    "        i += 1;",
    "    }",
    "    p",
    "}",
    "",
    "#[rustfmt::skip]",
    "pub static THEMES: &[(&str, ThemeDef)] = &[",
]

for theme in themes:
    overrides = ", ".join(f"({index}, {rgb(color)})" for index, color in theme["palette"])
    lines.extend(
        [
            f"    ({rust_str(theme['name'])}, ThemeDef {{",
            f"        name: {rust_str(theme['name'])},",
            f"        default_fg: {rgb(theme['default_fg'])},",
            f"        default_bg: {rgb(theme['default_bg'])},",
            f"        cursor: {rgb(theme['cursor'])},",
            f"        selection_fg: {rgb(theme['selection_fg'])},",
            f"        selection_bg: {rgb(theme['selection_bg'])},",
            f"        palette: palette(&[{overrides}]),",
            "    }),",
        ]
    )

lines.append("];")
lines.append("")

out_path.write_text("\n".join(lines), encoding="utf-8")
PY
